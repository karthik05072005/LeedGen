# ===========================
# LeadMachine Configuration
# ===========================

# Apify
APIFY_TOKEN=your_apify_token_here

# Apify Actor Config
SCRAPE_CITY=Bangalore
SCRAPE_CATEGORY=restaurants
SCRAPE_MAX_RESULTS=200

# Vercel
VERCEL_TOKEN=your_vercel_token_here

# WhatsApp (no config needed, just session folder)
WHATSAPP_SESSION_PATH=./.wwebjs_auth

# Schedule
DAILY_LEAD_LIMIT=25
CRON_TIME=0 10 * * *

# Min/Max delay between messages (minutes)
DELAY_MIN_MINUTES=15
DELAY_MAX_MINUTES=40
