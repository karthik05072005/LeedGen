{
  "name": "lead-machine",
  "version": "1.0.0",
  "description": "Fully automated lead generation and outreach system — scrape, build, deploy, record, and message businesses with zero human involvement.",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "setup": "node src/db.js",
    "scrape-only": "node -e \"import('./src/scraper.js').then(m => m.runScraper())\"",
    "send-test": "node -e \"import('./src/scheduler.js').then(m => m.runDailyPipeline())\"",
    "import-leads": "node src/importLeads.js"
  },
  "keywords": [
    "lead-generation",
    "automation",
    "whatsapp",
    "outreach",
    "scraping"
  ],
  "author": "Kodexa Tech",
  "license": "ISC",
  "dependencies": {
    "apify-client": "^2.10.0",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^16.4.7",
    "ffmpeg-static": "^5.3.0",
    "node-cron": "^3.0.3",
    "node-fetch": "^3.3.2",
    "playwright": "^1.49.1",
    "puppeteer": "^24.42.0",
    "puppeteer-screen-recorder": "^3.0.6",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.26.0",
    "winston": "^3.17.0"
  }
}
